{
  "AgentServer": {
    "Models": {
      "Catalog": {
        "qwen": {
          "BaseUrl": "http://ollama-api:11434/v1",
          "Model": "qwen2.5:3b",
          "ApiKey": "ollama",
          "NetworkTimeoutSeconds": 300
        },
        "granite": {
          "BaseUrl": "http://ollama-api:11434/v1",
          "Model": "granite4:3b",
          "ApiKey": "ollama",
          "NetworkTimeoutSeconds": 300
        },
        "granite-small": {
          "BaseUrl": "http://ollama-api:11434/v1",
          "Model": "granite4:1b",
          "ApiKey": "ollama",
          "NetworkTimeoutSeconds": 300
        }
      },
      "DefaultModel": "qwen",
      "QuickWorkModel": "granite"
    },

    // Back-compat: kept in sync with DefaultModel.
    "OpenAI": {
      "BaseUrl": "http://ollama-api:11434/v1",
      "Model": "qwen2.5:3b",
      "ApiKey": "ollama",
      "NetworkTimeoutSeconds": 300
    },

    "Sessions": {
      "Directory": ".agent/sessions"
    },
    "Logging": {
      "LogRpc": false,
      "LogLlmPrompts": false,
      "LogObservedEvents": false
    },
    "Core": {
      "CommitAssistantTextDeltas": true,
      "CommitReasoningTextDeltas": false
    },
    "Acp": {
      "PublishReasoning": false
    }
  }
}
